{
  "manifest_version": 3,
  "name": "TraceShot",
  "version": "0.1.0",
  "description": "Make team screenshots traceable",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "TraceShot"
  },
  "background": {
    "service_worker": "background.js"
  }
}
