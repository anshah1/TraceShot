{
  "manifest_version": 3,
  "name": "TraceShot",
  "version": "0.1.0",
  "description": "Make team screenshots traceable",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "clipboardWrite",
    "storage",
    "identity",
    "scripting"
  ],
  "oauth2": {
    "client_id": "245597955683-gf9rtha52o99vrc8p7q1qubs68se3mis.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "TraceShot",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
